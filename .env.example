# Copia este archivo a .env.local para desarrollo local. No se commitea (.gitignore).

# Base URL de la API REST (vacío mientras no exista backend, ver ROADMAP.md Fase 5)
VITE_API_BASE_URL=

# Llave de Google Maps (opcional, para geocodificación futura)
VITE_GOOGLE_MAPS_API_KEY=

# Token de Mapbox (opcional, para geocodificación futura)
VITE_MAPBOX_TOKEN=
